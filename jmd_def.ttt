$SPOOL N=GYSEV_EP4A; SEQ=R;
  {H|A?
    {E4?
      C=GY_520(A|B),											\
	  (3:(2-5*M_2421(|L))|(2-4*M_2421(|L),M_1420(|L)|M_1424(|L)))|					\
	  2:((2-3*M_2027(A|AL|B|BL))|(2-3*M_2026(A|B)(|L))|3:(2-3*(M_2027(A|AL|B|BL)|M_2026(A|B)(|L))));
      C=GY_520(A|B),GY_9423(|L),1-3*GY_148GGS(1|2|3|4|5);
      M=M1|M3|M4;											\
	C=GY_701B|(GY_701B,0-2*GY_8929B(|L),GY_701B);							\
	P=*; W=1;											\
