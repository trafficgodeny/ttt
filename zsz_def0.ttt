%*DEFINE(SECFIN=LT=45; FIN=S;)

%*DEF(FAK(K,T)=M=FOLLOW;TX/={%LEN(%T;)?%T;?[P:*]};TXX=<10;TXY=20;BL=25;C=($SELECT(CAT=%K;;D=S;WAY=A;MAX=10;DELIM=";"))![SS:10];)
%*DEF(FAV(V,T)=M=FOLLOW;TX/={%LEN(%T;)?%T;?[P:*]};TXX=<10;TXY=20;BL=25;C=($SELECT(SAMECAT=%V;;D=S;WAY=A;MAX=10;DELIM=";"))![SS:10];)
%*DEF(FAM(V,T)=M=FOLLOW;TX/={%LEN(%T;)?%T;?[P:*]};TXX=<10;TXY=20;BL=25;C=($SELECT(MIXED=%V;;D=S;WAY=A;MAX=10;DELIM=";"))![SS:10];)

%*DEF(FTV(V,H,T)=M=FOLLOW;TX/={%LEN(%T;)?%T;?[P:*]};TXX=<10;TXY=20;BL=25;C=($SELECT(SAMECAT=%V;;D=S;WAY=T*;MAX=10;DELIM=";"))![SP:,%H]; W=T%H;;)
%*DEF(FTVH(V,VH,TH,T)=M=FOLLOW;TX/={%LEN(%T;)?%T;?[P:*]};TXX=<10;TXY=20;BL=25;C=($SELECT(SAMECAT=%V;;D=S;WAY=T*;HEIGHT=%VH;;MAX=10;DELIM=";"))![SP:,%TH]; W=T%TH;;)
%*DEF(FTM(V,H,T)=M=FOLLOW;TX/={%LEN(%T;)?%T;?[P:*]};TXX=<10;TXY=20;BL=25;C=($SELECT(MIXED=%V;;D=S;WAY=T*;MAX=10;DELIM=";"))![SP:,%H]; W=T%H;;)

%*DEF(SAK(K,T)=TX/={%LEN(%T;)?%T;?[P:*]};TXX=<10;TXY=20;BL=25;C=($SELECT(CAT=%K;;WAY=A;MAX=1;))[SS:10];)
%*DEF(SAV(V,T)=TX/={%LEN(%T;)?%T;?[P:*]};TXX=<10;TXY=20;BL=25;C=($SELECT(SAMECAT=%V;;WAY=A;MAX=1;))[SS:10];)
%*DEF(SAM(V,T)=TX/={%LEN(%T;)?%T;?[P:*]};TXX=<10;TXY=20;BL=25;C=($SELECT(MIXED=%V;;WAY=A;MAX=1;))[SS:10];)

%*DEF(STK(K)=TX/={%LEN(%T;)?%T;?[P:*]};TXX=<10;TXY=20;BL=25;C=($SELECT(CAT=%K;;WAY=T*;MAX=1;))[SS:10];)
%*DEF(STV(V,T)=TX/={%LEN(%T;)?%T;?[P:*]};TXX=<10;TXY=20;BL=25;C=($SELECT(SAMECAT=%V;;WAY=T*;MAX=1;))[SS:10];)
%*DEF(STVH(V,VH,T)=TX/={%LEN(%T;;)?%T?[P:*]};TXX=<10;TXY=20;BL=25;C=($SELECT(SAMECAT=%V;;WAY=T*;HEIGHT=%VH;;MAX=1;))[SS:10];)
%*DEF(STM(V)=TX/={%LEN(%T;)?%T;?[P:*]};TXX=<10;TXY=20;BL=25;C=($SELECT(MIXED=%V;;WAY=T*;MAX=1;))[SS:10];)

