	TGIF_RBBX_43010,TGIF_RBBX_43008,TGIF_RBBX_43006,TGIF_RBBX_43005,TGIF_RBBX_43004,		\
	TGIF_RBBX_43002,TGIF_RBBX_60002,TGIF_RBBX_60004,TGIF_RBBX_60012,TGIF_RBBX_60013,		\
	TGIF_RBBX_63002,TGIF_RBBX_63004,TGIF_RBBX_63006,TGIF_RBBX_80717,TGIF_RBBX_80716,		\
	TGIF_RBBX_84702,TGIF_RBBX_84706,TGIF_RBBX_84707,TGIF_RBBX_84709,TGIF_RBBX_84711,		\
	TGIF_RBBX_84712R,TGIF_RBBX_84713,TGIF_RBBX_84714,TGIF_RBBX_84716,TGIF_RBBX_84803,		\
	TGIF_RBBX_84804,TGIF_RBBX_85701;								\
      D=R;
    C=2*TGIF_BNSF_C408W1,TGIF_BNSF_C408W1L,TGIF_CSX_52COIL,TGIF_BNSF_COIL1,TGIF_EJE_COIL1,		\
	TGIF_EJE_COIL2,TGIF_CSX_COIL2,TGIF_NSA_COIL,TGIF_BNSF_COIL,TGIF_DTI_COIL,TGIF_CR_COIL,		\
	TGIF_CNW_COIL,TGIF_UP_86HC5B,TGIF_UP_86HC4Y,5*TGIF_NSA_TIE2,TGIF_CN_CHOP,TGIF_DRGW_ACFHOP,	\
	TGIF_CPR_AUTORACK2,TGIF_CPR_AUTORACK,TGIF_DTI_86HC2V2,TGIF_DTI_86HC2B1;				\
      D=R;
    C=TGIF_BN_F7A1L,TGIF_BN_F7B1,TGIF_BNSF_SD75ML~STE,TGIF_BNSF_SNOQUALPASS,TGIF_BNSF_JOHNSREED,	\
	TGIF_BNSF_FREDHARVEY,TGIF_BNSF_VALLEYVIEW,TGIF_BNSF_GLACIERVIEW,TGIF_BNSF_REDRIVER;		\
      D=L;
  $ENDPATH
# Yard throat - single line
#   $PATH Y=7; NL;
#   $ENDPATH
# Road - in both directions
  $PATH Y=7; NL;
    M=FOLLOW;												\
      C=15*(TGIF_LOG(1E|2|3|4|5|6|7|8)|TGIF_WCHIPTR(0|1|2|3|4|5|6|7|8)[!E]);				\
      D=R;
  $ENDPATH
  $PATH Y=7; NL;
    M=FOLLOW;												\
      C=15*(TGIF_LOG(1A|1B|2A|3A|4A|5A|6A|7A|8A)|TGIF_WCHIPTR(0|1|2|3|4|5|6L|7|8));			\
      D=L;
  $ENDPATH
# In-plant track
  $PATH Y=7;												\
      FG=TGIF_WOODCHIPPER2:10;										\
      NL;
    C=TGIF_CSX_BHT3,TGIF_IC_BH2,TGIF_IC_BH3,TGIF_RI_BH1A,TGIF_LN_BH2,TGIF_SOU_BH1A,TGIF_IC_BH3,		\
	TGIF_CRI_SW1L;											\
      D=R;
    C=TGIF_CRI_SW1L,TGIF_IC_BH1,TGIF_CSX_BHT2[!E],TGIF_SOO_56BH,2*TGIF_LN_BH4;				\
      D=L;
    C=TGIF_RACKFLAT_GPSX1_LD,TGIF_RACKFLAT_GPSX2_LD,TGIF_RACKFLAT_GPSX3_LD,TGIF_RACKFLAT_GPSX4_LD,	\
	TGIF_BNSF_SW1500BL,TGIF_BNSF_SW1500B;								\
      D=R;
    C=TGIF_BN_SW1500~STE,TGIF_BN_SW1500CALFL,TGIF_BN_84LOG2,TGIF_BN_84LOG3,TGIF_BN_84LOG4,		\
	TGIF_BN_84LOG5;											\
      D=R;
  $ENDPATH
# Woodchp cars on the trestle
  $PATH Y=43;												\
      FG=(TGIF_PAPERMILL2:>100,-36;TGIF_TRESTLE1(10*A,B,10*A):..,-36);					\
      V=1;												\
      NL;
    C=TGIF_FPBX_WOODCHIP1,TGIF_WP_SW7;									\
      D=R;
    C=TGIF_WP_SW7,TGIF_FPBX_WOODCHIP1[!E];								\
      D=L;
    C=TGIF_USCX_WOODCHIP,TGIF_WP_SW7;									\
      D=R;
    C=TGIF_WP_SW7,TGIF_USCX_WOODCHIP[!E];								\
      D=L;
    C=TGIF_SOU_WOODCHIP2,TGIF_SLSF_S12;									\
      D=R;
    C=TGIF_SLSF_S12,TGIF_SOU_WOODCHIP2[!E];								\
      D=L;
    C=TGIF_CSX_WOODCHIP3,TGIF_WP_SW7;									\
      D=R;
    C=TGIF_WP_SW7,TGIF_CSX_WOODCHIP3[!E];								\
      D=L;
    C=TGIF_FPBX_WOODCHIP1,TGIF_SLSF_S12;								\
      D=R;
    C=TGIF_SLSF_S12,TGIF_FPBX_WOODCHIP1[!E];								\
      D=L;
    C=TGIF_GWS_WOODCHIP,TGIF_WP_SW7;									\
      D=R;
    C=TGIF_WP_SW7,TGIF_GWS_WOODCHIP[!E];								\
      D=L;
    C=TGIF_WC_WOODCHIP,TGIF_SLSF_S12;									\
      D=R;
  $ENDPATH
# In-plant way for the crawler
  $PATH Y=7;												\
      FG=TGIF_LOGPILE:20;										\
      NL;
    M=BACK;												\
      C=TGIF_CRAWLER3;											\
      D=R; V=0.5; P=20+20;
    C=TGIF_LOGLOADER1;											\
      D=L; V=2;
    M=BACK;												\
      C=TGIF_TIMBERCRAWLER2;										\
      D=R; V=0.5; P=20+20;
  $ENDPATH
$ENDSCENE

