$POOL N=POOL_MESA;
  C=TGIF_ATSF_RSD5L,TGIF_ATSF_XM40O,TGIF_ATSF_XM40,TGIF_SP_HOP,TGIF_UP_XM40O,TGIF_ATSF_CAB4;		\
    V=4;
  C=(<TGIF_ATSF_F7(AL,BL,B,A)~RPA),1-2*ATSF_PB,3-5*ATSF_PA,ATSF_PD,2-3*ATSF_PP;				\
    V=9;
  C=(<TGIF_ATSF_FT(AL,BL,A)),4*TGIF_UP_XM40,2*TGIF_SP_HOP,TGIF_UP_XM40,TGIF_SOO_XM40,TGIF_UP_XM40,	\
      TGIF_UP_XM40O,TGIF_MKT_XM40,TGIF_PFE_R40_14LL,TGIF_SLSF_XM40,TGIF_ATSF_XM40O,TGIF_SSW_XM40,	\
      TGIF_SSW_XM40,TGIF_SP_GON2,TGIF_ATSF_CAB4;							\
    V=7;
  C=(<TGIF_ATSF_F7(ABL,BBL,BB,AB)~RPA),13*TGIF_TANK_40,TGIF_ATSF_CAB4;					\
    V=5-8;
  C=(<TGIF_ATSF_GP7(L,|L,)),TGIF_ATSF_GP7,TGIF_ATSF_GP7,TGIF_ACL_XM40,TGIF_UP_XM40,TGIF_ATSF_XM40,	\
      2-4*TGIF_SP_HOP,3-6*TGIF_TANK_40,TGIF_SSW_XM40,5-9*TGIF_SP_HOP,TGIF_ATSF_CAB4;			\
    V=4-7;
$ENDPOOL

$POOL N=POOL_AUTUMNHILLS;
  C=TGIF_NW_JAWNHENRY~RPA,TGIF_NW_HOP1,TGIF_SP_HOP,TGIF_SP_GON2,4*TGIF_NW_XM40,TGIF_UP_XM40,		\
      2*TGIF_TANK_40,TGIF_NW_HOP1,TGIF_UP_XM40O,TGIF_NW_CAB;						\
    V=4-6;
