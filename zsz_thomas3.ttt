    TH3_SPENCER|TH3_STEVEN|TH3_VINNIE|TH3_YONGBAO
$DEF TH3_D2X=TH3_LEONARD|TH3_BEAR|TH3_NOOR_JEHANL|TH3_DEREK(1|2|3|4)(|L)|TH3_CL66_D17|TH3_CHOPPER|	\
    TH3_HARPERL|TH3_BEAR(1|2|3|4)(|L)|TH3_D1023|TH3_BOCO(1|2|3|4)(|L)|TH3_BR_31120(|L)|			\
    TH3_DIESEL1(|L)|TH3_BR_47111(A|B)(|L)|TH3_BR47_W2(|L)|TH3_D199_(1|1L|2|2L|3|3L|4)|			\
    TH3_D287_(1|1L|2|2L)|TH3_CL40_(1|2|3|4|5|6)(|L)

$POOL NAME=TH3_P;
  C=TH3_THOMAS,TH3_ANNIE1,TH3_CLARABEL1;
  C=TH3_S1X,TH3_BRANCH_(M(1|2|3)|O(1|2)|CH|G|N)_(0-2*(F|C|T)(|L),(C|T)B($DIR(,L)));
  C=TH3_S2X,2-3*(TH3_OBOG_O1_(F|C|T)(|L)),TH3_OBOG_O1_TB($DIR(L,));
$ENDPOOL

$POOL NAME=TH3_XL;
  C=TH3_CONNOR1|TH3_CONNOR2,1-3*TH3_MK3_CON_TF(|L),|TH3_MK3_CON_TRUK|TH3_MK3_CON_TRSB,			\
      2-4*TH3_MK3_CON_T(|G)S(|L);
$ENDPOOL

$POOL NAME=TH3_X;
  C=TH3_CAITLIN1|TH3_CAITLIN2,1-3*TH3_MK3_CAI_TF(|L),|TH3_MK3_CAI_TRUK|TH3_MK3_CAI_TRSB,		\
      2-4*TH3_MK3_CAI_T(|G)S(|L);
  C=TH3_S2X,												\
      TH3_MAU_(GC|RC|CHC|BC|LIM|KNX|DO|SB|ROY|BCC|BCHC|BE|ML|BLB|SRG)					\
      _(2-4*(FK|CK|TK)(|L),$DIR(BCKL,BCK));
  C=TH3_D2X,TH3_MK1_(CC|K1|GC|O|OC|WC|BE|CHC|NW|IC)_(2-4*(FO|TSO|CK)(|L),(BSK|BCK)$DIR(,L));
$ENDPOOL

$POOL NAME=TH3_F1;
  C=TH3_S1X,$SELECT(CAT=TH3_FRO;CNT=1-4;);
$ENDPOOL

