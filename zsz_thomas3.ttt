$DEF TH3_S1X=TH3_ARTHUR|TH3_ASHIMA|TH3_BELLE|TH3_BEN|TH3_BILL|TH3_CARLIE|TH3_CORINA|TH3_DUCK|		\
    TH3_FRANZ|TH3_GINA|TH3_JAKE|TH3_LADY|TH3_LESHAWNA|TH3_LILY|TH3_LIZ|TH3_NEIL|TH3_PERCY|TH3_PORTER|	\
    TH3_RAJIV|TH3_ROSIE|TH3_RYAN|TH3_SAMSON|TH3_SANDY|TH3_SHEFFIELD|TH3_SONNY|TH3_STANLEY|		\
    TH3_STEFANIE|TH3_STEPNEY|TH3_TIMOTHY
$DEF TH3_S2X=TH3_ALAIN|TH3_ALEX|TH3_ALFRED(1|2)|TH3_ALICE|TH3_AMY|TH3_AXEL|TH3_BERTHA|TH3_CARLOS|	\
    TH3_CECIL|TH3_CHRIS|TH3_CRYSTAL|TH3_DONALD|TH3_DOUGLAS|TH3_EAGLE|TH3_EDWARD(1|2|3)|TH3_ELLIE|	\
    TH3_ELSA|TH3_EMILY|TH3_FLYING_SCOTSMAN(1|2)|TH3_FRIEDA|TH3_GADGET|TH3_GARETH|TH3_GEOFFREY|		\
    TH3_GHOST|TH3_GORDON(1|2|_DOMELESS|_NEWTENDER1|_NEWTENDER2|_TOWCABLE)|TH3_HANK|TH3_HENRY(1|2)|	\
    TH3_HIRO|TH3_HUSH|TH3_JAMES(1|2|3|5R)|TH3_JUSTIN|TH3_KING_EDWARD7|TH3_LARA|TH3_LENNY|TH3_MOLLY|	\
