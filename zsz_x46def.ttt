$POOL N=NEWDELHI_M;
  TX=New Delhi Metro;											\
    C=<X46_DMRC_(A|B|C|D)(1[!L],2[!L],2,1);								\
    IMGY=255;
  TX=New Deli Metro;											\
    C=<X46_DMRC_MOVIA_(B|Y)(1[!L],2[!L],2,1);								\
    IMGY=237;
  TX=Gurgaon (India)Metro;										\
    C=<X46_RMGL_T(1[!L],2,1);										\
    IMGY=255;
$ENDPOOL

